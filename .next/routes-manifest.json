{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ],
      "regex": "^(?:/(.*))(?:/)?$"
    }
  ],
  "dynamicRoutes": [
    {
      "page": "/admin/properties/[id]",
      "regex": "^/admin/properties/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/properties/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/admin/properties/[id]",
      "regex": "^/api/admin/properties/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/admin/properties/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/properties/[slug]",
      "regex": "^/properties/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/properties/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/valuation/[location]",
      "regex": "^/valuation/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPlocation": "nxtPlocation"
      },
      "namedRegex": "^/valuation/(?<nxtPlocation>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/admin/contacts",
      "regex": "^/admin/contacts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/contacts(?:/)?$"
    },
    {
      "page": "/admin/dashboard",
      "regex": "^/admin/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/dashboard(?:/)?$"
    },
    {
      "page": "/admin/inquiries",
      "regex": "^/admin/inquiries(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/inquiries(?:/)?$"
    },
    {
      "page": "/admin/login",
      "regex": "^/admin/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/login(?:/)?$"
    },
    {
      "page": "/admin/properties",
      "regex": "^/admin/properties(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/properties(?:/)?$"
    },
    {
      "page": "/admin/properties/new",
      "regex": "^/admin/properties/new(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/properties/new(?:/)?$"
    },
    {
      "page": "/admin/valuation-requests",
      "regex": "^/admin/valuation\\-requests(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/valuation\\-requests(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/estate-agency",
      "regex": "^/estate\\-agency(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/estate\\-agency(?:/)?$"
    },
    {
      "page": "/insights",
      "regex": "^/insights(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/insights(?:/)?$"
    },
    {
      "page": "/properties",
      "regex": "^/properties(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/properties(?:/)?$"
    },
    {
      "page": "/robots.txt",
      "regex": "^/robots\\.txt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/robots\\.txt(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/valuation",
      "regex": "^/valuation(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/valuation(?:/)?$"
    },
    {
      "page": "/valuation-services",
      "regex": "^/valuation\\-services(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/valuation\\-services(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "RSC",
    "varyHeader": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
    "prefetchHeader": "Next-Router-Prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "Next-Router-Segment-Prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  },
  "rewrites": []
}